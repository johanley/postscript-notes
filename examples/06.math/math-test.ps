%!PS

(../02.using/using.ps) run 
(math.ps) using
(../01.base/base.ps) using
(../03.unit-test/unit-test.ps) using

/math-unit-tests {
  [
    [ [0 10] {midpoint} [5] ]
    [ [0 -10] {midpoint} [-5] ]
    [ [6 8] {midpoint} [7] ]
    [ [-6 -8] {midpoint} [-7] ]
    [ [6 9] {midpoint} [7.5] ]
    
    [ [10 20 50] {pct-between} [15] ]
    [ [1 -1 50] {pct-between} [0] ]
    [ [-1 1 50] {pct-between} [0] ]
    [ [1 1 50] {pct-between} [1] ]
    [ [1 1 -50] {pct-between} [null] ]
    
    [ [ [] ] {max} [null] ]
    [ [ [10] ] {max} [10] ]
    [ [ [0 1] ] {max} [1] ]
    [ [ [0 1 2 99] ] {max} [99] ]
    [ [ [-99 -998 99] ] {max} [99] ]
    
    [ [ [] ] {min} [null] ]
    [ [ [10] ] {min} [10] ]
    [ [ [0 1] ] {min} [0] ]
    [ [ [0 1 2 99] ] {min} [0] ]
    [ [ [-99 -998 99] ] {min} [-998] ]

    [ [0 -20 20 100] {rescale} [50] ]
    [ [10 -20 20 100] {rescale} [75] ]
    [ [-10 -20 20 100] {rescale} [25] ]
    [ [-20 -20 20 100] {rescale} [0] ]
    [ [20 -20 20 100] {rescale} [100] ]

    % [
      % [[
        % [0 0]     
        % [0 10]     
        % [10 10]     
        % [0 10]     
      % ]] {points-bbox} [[0 0 10 10]]   % this fails because of rounding, which I haven't accounted for
    % ]
  ]
  /deep-eq?
  unit-test-suite
} def

math-unit-tests
[/num-tests /num-fails] defi

(Num tests: ) ==  num-tests ==
(Num fails: ) ==  num-fails ==

quit
