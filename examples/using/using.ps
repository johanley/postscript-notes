%!PS-Adobe-3.0

% this table remembers which files have already been passed to the 'run' operator
userdict /using-table <<(using.ps) true>> put

% file-name file-sep-int -> file-name
% extract the simple file name (blah.ps) from a string (..\other\blah.ps).
% this is needed because the same file can be 'run' using different file name strings.
% the file-sep-int is the integer corresponding to the file separator on your operating system.
/simple-file-name {
  3 dict begin
    /sep exch def
    /file-name exch def
    file-name % default result (if no sep found)
    file-name length 1 sub -1 0 {
      % backwards over the file-name, looking for sep
      /idx exch def
      file-name idx get  sep eq {
        pop % remove the default result
        file-name idx 1 add   file-name length 1 sub idx sub   getinterval
        exit
      } if
    } for
  end
} bind def

% (file-name) -> .
% use the 'run' operator on the given file name, but only once.
% here, '..\other\blah.ps' is treated the same as 'blah.ps' (for example); only the simple file name matters.
/using {
  % IS THERE ANY WAY OF DETECTING WHAT THE OS IS? 
  % (One option is to use the nix version regardless of OS; it seems to work fine on Windows anyway).
  % 92 = \134 octal is '\' Windows
  % 47 = \057 octal is '/' Nix
  92 simple-file-name dup  
  dup ==
  using-table exch known not 
    {dup run 
     using-table exch true put
     (  run once) ==
    } 
    {pop (  already run) == }
  ifelse
} bind def
