%!PS-Adobe-3.0
%%Title: Ragged Right
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-02-26
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612.0 792.0 60 white ()
%%DocumentNeededResources: font Helvetica Helvetica-Bold Helvetica-Oblique
%%BoundingBox: 0 0 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog

% RENDER TEXT WITH A RAGGED-RIGHT MARGIN.

(../02.using/using.ps) run

(../01.base/base.ps) using
(../04.debug/debug.ps) using
(../05.font-management/fonts.ps) using
(../07.strings/strings.ps) using
(../08.text-align/text-align.ps) using

% leading /left-limit /right-limit /end-of-line [runs]
%
% (The name objects passed here are all names of procs.)
%
% Render runs of text in a ragged-right style.
% A 'run' of text is contiguous text that shares the same font/color/look.
% For brevity, each run is modeled as an array:
%    [/render-proc (...txt...)]
% The /render-proc accepts a string, and shows it on the page (it is called one word at a time).
% If a render-proc varies the y-level, it should ensure that currentpoint.y is put 'back to where it was'.
% The text should not have any newline characters in it; they will be ignored here.
%
% The left-limit and right-limit procs map a y-value to a corresponding left-or-right boundary.
% Those limits can be fixed or dynamic; a dynamic style allows for text to around an rectangular image (for example).
% 
% The /end-of-line proc defines what to do when showing the next word in the current font WOULD result in 
% overshooting beyond the right-limit. Having this in a proc lets you experiment with different policies.
%
% Before calling this proc, the caller:
%  - defines a work box: 
%      - translates the origin of the CTM to the bottom left
%      - defines /wd and /ht for the width and height of the work-box
%  - moves to a currentpoint at the top-left of the work-box (0 ht moveto)
/text-flow-ragged-right {
  [/leading /left-limit /right-limit /end-of-line /runs] {
    /SPACE ( ) def
    runs { 
      % [{render} (str)]
      aload pop 
      exch % (str) {render}
      /render defi
      str-words { % each word (splits on whitespace)
        /word defi
        word /render test-off-page % dx dy  
        pop % dx  (I'm assuming dy is 0 here!)
        /word-width defi
        currentpoint % x y 
        right-limit %  x right-lim
        exch % right-lim x 
        word-width add % right-lim x-new
        exch % x-new right-lim
        sub /overshoot defi
        overshoot 0 le { 
          word SPACE str-concat render
        } { 
          end-of-line
        } ifelse
      } forall
    } forall 
    carriage-return-line-feed % one way of implementing paragraphs
    2 em 0 rmoveto  
  } def-tmp
} bind def

% str /render -> dx dy
% Render a single word using nulldevice, simply to calc the change in the currentpoint.
% Using nulldevice means that no marks are actually made on the page.
/test-off-page { 
  % Q: should I use 'stringwidth' instead?
  % The font is 'buried' in the /render proc's implementation.
  % Can't the /render change the currentpoint in some weird way, in some cases?
  gsave % the currentpoint
  4 dict begin 
    nulldevice % so that no marks are made on the page!
    %0  ht 100 mul  moveto % this will be way off the page, if you prefer
    currentpoint 
    [/x0 /y0] defi
    cvx exec 
    currentpoint 
    [/x1 /y1] defi
    x1 x0 sub % dx
    y1 y0 sub % dy
  end
  grestore % back to the 'real' currentpoint
} bind def

% Move the currentpoint to the start of the next line.
% This may also finish the current page, and start a new one.
/carriage-return-line-feed {
  currentpoint exch pop dup % y y
  0 lt {
    pop showpage % calls /BeginPage when the next page is init'ed
  } {
    left-limit % x-left
    currentpoint exch pop % x-left y
    leading sub % x-left y-down
    moveto  
  } ifelse
} bind def

% WARNING: these helper-procs assume certain names in the currentdict.

/eol-simple {
  carriage-return-line-feed
  word SPACE str-concat render
} bind def

% y -> x-right
/right-limit-fixed { pop wd } bind def

% y -> x-left
/left-limit-fixed { pop 0 } bind def

% Procs for rendering a run of text.

% str
% Regular text.
/REG { 
  (regular) 100 use-font show 
} bind def

% str
% Italic text.
/ITAL { 
  (italic) 100 use-font show 
} bind def

% str
% Bold text.
/BOLD { 
  (bold) 100 use-font show 
} bind def

% int - number of times showpage has been called: 0, 1,...
% The passed int can be used to provide a page number.
% For each new page, the initgraphics operator is called. 
% It resets many items, including the CTM, path, and currentpoint.
% The font is retained, however.
/start-new-page {
  pop
  (Starting new page) ==
  % the work-box needs to be re-set for each new page
  wd 10 pct   ht 5 pct translate % bottom left of the work-box
  0 ht moveto % where the text will start
} bind def

%%EndProlog

%%BeginSetup               
  /page-width  8.5 72 mul def
  /page-height 11 72 mul def % absolute values
  /wd page-width 80 pct def   
  /ht page-height 90 pct def   
  <<
    /PageSize [page-width  page-height]
    /BeginPage {start-new-page}
  >> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  /MyRegular /Helvetica latinize
  /MyBold /Helvetica-Bold latinize
  /MyItalic /Helvetica-Oblique latinize
  << 
    (regular) /MyRegular
    (bold) /MyBold
    (italic) /MyItalic
  >>
  page-height 1.5 pct 
  init-my-fonts
%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
 /pgsave save def     
%%EndPageSetup

  (regular) 100 use-font
  2.5 em  % this needs a current font
  {left-limit-fixed}  % where to start a line 
  {right-limit-fixed} % where to end a line 
  {eol-simple} % what to do when an overshoot is detected
  [ % runs of text
[{REG}(It is certainly better for yourself, and more for the security of mankind, that you should live in some \
rural abode, than appear in the world; such persons, as you, are fatal to the public tranquillity, and do mischief \
without ever desigining it: but, I must own, when)]
[{ITAL} (belles)]
[{REG} (and)]
[{ITAL} (beaux)]
[{REG} (retire to country shades for the sake of heavenly \
contemplation, the world will be well reformed. A hermit's life might be tolerable, while the serious hours are divided \
between Hyde Park and the Opera; but a more distant retreat, in the full pride of your charms and youth, would be very \
extraordinary.)]
  ]
  text-flow-ragged-right 

  2.5 em  % this needs a current font
  {left-limit-fixed}  % where to start a line 
  {right-limit-fixed} % where to end a line 
  {eol-simple} % what to do when an overshoot is detected
  [ % runs of text
[{REG}(One of the most salient features of our culture is that there is so much bullshit. Everyone knows this. \
Each of us contributes his share. But we tend to take the situation for granted. Most people are rather confident of their \
ability to recognize bullshit and to avoid being taken in by it. So the phenomenon has not aroused much deliberate concern, nor \
attracted much sustained inquiry. In consequence, we have no clear understanding of what bullshit is, why there is so much of it, \
or what function it serves. And we lack a conscientiously developed appreciation of what it means to us. In other words, we have \
no theory. I propose to begin the development of a theoretical understanding of bullshit, mainly by providing some tentative and \
exploratory philosophical analysis. I shall not consider the rhetorical uses and misuses of bullshit. My aim is simply to give a \
rough account of what bullshit is and what it is not - or (putting it somewhat differently) to articulate, more or less sketchily \
the structure of its concept. Any suggestion about what conditions are logically both necessary and sufficient for the constitution \
of bullshit is bound to be somewhat arbitrary. For one thing, the expression)
]
[{ITAL}(bullshit)]
[{REG}(is often employed quite loosely - simply as a generic term of abuse, with no very specific literal meaning. For another, \
the phenomenon itself is so vast and amorphous that no crips and perspicuous analyisis of its concept can avoid being procrustean. \
Nonetheless it should be possible to say something helpful, even thought it is not likely to be decisive. Even the most basic \
and preliminary questions about bullshit remain, after all, not only unanswered but unasked. So for as I'm aware, very little \
work has been done on this subject. I have not undertaken a survey of the literature, partly because I do not know how to go \
about it. To be sure, there is one quite obvious place to look - the)]
[{ITAL}(Oxford English Dictionary.)]
[{REG}(The)]
[{ITAL}(OED)]
[{REG}(has an entry for)]
[{ITAL}(bullshit)]
[{REG}(in the supplementary volumes, and it also has entries for various pertinent uses of the word)]
[{ITAL}(bull)]
[{REG}(and some related terms. I shall consider some of these entries in due course. I have not consulted dictionaries in \
languages other than English, because I do not know the words for bullshit or bull in any other language. Another worthwhile \
source is the title essay in)]
[{ITAL}(The Prevalence of Humbug)]
[{REG}(by Max Black. I am uncertain just how close in meaning the word)]
[{ITAL}(humbug)]
[{REG}(is to the word)]
[{ITAL}(bullshit.)]
[{REG}(Of course, the words are not freely and fully interchangeable; it is clear that they are used differently. But the \
difference appears on the whole to have more to do with considerations of gentility, and certain other rhetorical parameters, \
than with the strictly literal modes of significance that concern me most. It is more polite, as well as less intense, to say \
"Humbug!" than to say "Bullshit!" For the sake of this discussion, I shall assume that there is no other important difference between the two.)]
  ]
  text-flow-ragged-right 


pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF 