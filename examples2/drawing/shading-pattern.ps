%!PS-Adobe-3.0
%%Title: Shading Pattern
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-03-04
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612 792 60 white ()
%%DocumentNeededResources: font Helvetica
%%BoundingBox: 10 10 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog
%%EndProlog

%%BeginSetup               
  /page-width  612 def
  /page-height 792 def 
  <</PageSize [page-width  page-height]>> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues
%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
  /pgsave save def     
  /Times-Roman 15 selectfont
%%EndPageSetup

  % KenS: 
  % https://stackoverflow.com/questions/40112220/type-3-function-procedure-in-post-script

  gsave
    0.480 setlinewidth
    1 setlinecap
    1 setlinejoin
    0 setgray

    % yields the color value (greyscale here) between the start-end of the linear axis
    /color_value <<
      /FunctionType 2  % y = C0 + (C1 - C0)*x^N  polynomial functions
      /Domain[0 1]     %  typical for interpolation functions
      /C0 [0.2]
      /C1 [0.8]
      /N 1             % simple affine function in this case
    >> def
    
    <<
      /PatternType 2   % shading
      /Shading
      <<
        /ShadingType 2  %   AXIAL SHADING using a specified line segment
        /ColorSpace [/DeviceGray]  % can't be a pattern
        /Background [0.5]
        %/BBox
        /Coords [0 0 500 500]   % line segment: start-end of the linear axis (a diagonal, here)
        /Domain [0 1] % the default; maps points along the line segment into this range
        /Function color_value
        /Extend [false false]    % the default - don't extend beyond the start-end of the axis
      >> 
    >>
    matrix makepattern setpattern

    % draw a box and fill it with the shading pattern    
    10 10 moveto
    10 500 lineto
    300 500 lineto
    300 10 lineto
    closepath
    gsave  fill  grestore  0 setgray  stroke
  grestore

pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF