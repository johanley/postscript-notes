%!PS-Adobe-3.0
%%Title: Snowflake
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-03-03
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612 792 60 white ()
%%DocumentNeededResources: font Times-Roman
%%BoundingBox: 10 10 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog
% https://stackoverflow.com/questions/12381887/understanding-recursive-koch-snowflake-function-in-postscript
/kochR {
  2 copy ge {dup 0 rlineto}
    {
      3 div
      2 copy kochR
      60 rotate
      2 copy kochR
      -120 rotate
      2 copy kochR
      60 rotate
      2  copy kochR
    } ifelse
    pop pop
} def
%%EndProlog 

%%BeginSetup               
  /page-width  612 def
  /page-height 792 def 
  <</PageSize [page-width  page-height]>> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues
%%EndSetup 

%%Page: (First Round) 1
%%BeginPageSetup 
  /pgsave save def     
  /Times-Roman 15 selectfont
%%EndPageSetup


  page-width 0.5 mul  page-height 0.8 mul translate 

  0 0 moveto
  27 81 kochR

  0 27 moveto
  9 81 kochR

  0 54 moveto
  3 81 kochR

  0 81 moveto
  1 81 kochR
  stroke

pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF