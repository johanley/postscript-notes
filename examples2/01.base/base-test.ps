%!PS

(..\\02.using\\using.ps) run 
(base.ps) using
(..\\03.unit-test\\unit-test.ps) using

/base-unit-tests {
  [
    [ [1 100] {pct} [1] ]
    [ [-1 100] {pct} [-1] ]
    [ [100 -1] {pct} [-1] ]
    [ [100 100] {pct} [100] ]
    [ [0 100] {pct} [0] ]
    %[ [100 -20] {pct} [-20] ]  % this fails because of rounding, which I haven't accounted for
    [ [100 50] {pct} [50] ]
    
    [ [1 5 /integertype] {same-type?} [true] ]
    [ [1 5.0 /integertype] {same-type?} [false] ]
    [ [1.0 5.0 /realtype] {same-type?} [true] ]
    [ [1 5.0 /realtype] {same-type?} [false] ]
    [ [(a) (b) /stringtype] {same-type?} [true] ]
    [ [[1 (a)] [true] /arraytype] {same-type?} [true] ]

    [ [[1 2]] {last} [2] ]
    [ [[1]] {last} [1] ]
    [ [[]] {last} [null] ]

    [ [[1 2]] {first} [1] ]
    [ [[(a)]] {first} [(a)] ]
    [ [[]] {first} [null] ]

    [ [1 1] {deep-eq?} [true] ]
    [ [(a) (a)] {deep-eq?} [true] ]
    [ [(a) /a] {deep-eq?} [true] ]  % valid! see the docs for 'eq'
    [ [/a (a)] {deep-eq?} [true] ]
    [ [/abc /abc] {deep-eq?} [true] ]
    [ [1.1 1.1] {deep-eq?} [true] ]
    [ [1 1.0] {deep-eq?} [true] ]
    [ [true true] {deep-eq?} [true] ]
    [ [null null] {deep-eq?} [true] ]
    [ [ [1 2 3] [1 2 3] ] {deep-eq?} [true] ]
    [ [ 
        [1 2 [3 4]] 
        [1 2 [3 4]] ] {deep-eq?} [true] ]
    [ [ <<(a) 123>> <<(a) 123>> ] {deep-eq?} [true] ]
    [ [ <<(a) 123>> <</a 123>> ] {deep-eq?} [true] ]
    
    [ [1 0] {deep-eq?} [false] ]
    [ [(a) (b)] {deep-eq?} [false] ]
    [ [1 (a)] {deep-eq?} [false] ]
    [ [ [1 2 3] [1 2] ] {deep-eq?} [false] ]
    [ [ 
        [1 2 [3 4]] 
        [1 2 [3 5]] ] {deep-eq?} [false] ]
    [ [ <<(a) 123>> <<(a) 124>> ] {deep-eq?} [false] ]
    [ [ <<(a) 123>> <<(a) 123 (b) 456>> ] {deep-eq?} [false] ]

  ]
  unit-test-suite
} def

base-unit-tests
[/num-tests /num-fails] defi

(Num tests: ) ==  num-tests ==
(Num fails: ) ==  num-fails ==

quit
