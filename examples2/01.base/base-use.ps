%!PS-Adobe-3.0
%%Title: Example of a Document Structuring Conventions (DSC) document.
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-02-23
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612.0 792.0 60 white ()
%%DocumentNeededResources: font Helvetica
%%BoundingBox: 0 0 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog

  % The first-line header '%!PS-Adobe-3.0' informs tools (but not the PS interpreter) that:
  %   - the file is an executable PostScript program
  %   - the document follows the Document Structuring Conventions (DSC), version 3.0.
  %     The info in DSC comments are not used by the core PS interpreter, but by other tools.
  %     The data in DSC comments are 'advisory'. The data should be accurate, but 
  %     tools never verify that DSC data agree with the output document. 
  % 
  %  The documentation for the DSC is in the 2ND EDITION of the Red Book (not the 3rd edition).
  
  % -- most of your PostScript procedures appear here, in the Prolog section --
  
  % num num -> num
  % the percentage of a number
  % example: 80 25 pct yields 20
  % NOTE: this simple proc is surprisingly useful. 
  /pct {
    0.01 mul mul
  } bind def
  % the docs recommend that 'bind' be used if 
  % the proc is called more than a few times

  % here's an example of including a file in the body of your program.
  % this simply injects the content of the file at this location, and starts to interpret it
  % as normal PostScript content.
  (included-file.ps) run

%%EndProlog 

%%BeginSetup               
  /page-width  8.5 72 mul def
  /page-height 11 72 mul def % absolute values
  <</PageSize [page-width  page-height]>> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues
%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
 /pgsave save def     
%%EndPageSetup

  % set the font, and show some text near the top of the page
  /Helvetica 15 selectfont
  page-width 10 pct 
  page-height 90 pct moveto 
  (Hello Bratislava.) show
  
  % use the content of the included file here
  % just output to stdout in this case
  25 30 midpoint ==  

pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF 