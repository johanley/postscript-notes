%!PS-Adobe-3.0
%%Title: Fixed Line Breaks
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-02-25
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612.0 792.0 60 white ()
%%DocumentNeededResources: font Helvetica Helvetica-Bold Helvetica-Oblique Consolas Consolas-Italic
%%BoundingBox: 0 0 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog

% RENDER TEXT WITH KNOWN LINE BREAKS.
% The text doesn't cross a page break.
% This is the simplest case for laying out lines of text on a single page.

(../01.base/base.ps) run
(../02.using/using.ps) run
(../05.font-management/fonts.ps) using
(../07.strings/strings.ps) using
(../08.text-align/text-align.ps) using

% [str]
% Render several lines of text with fixed line breaks, using the current font.
% The current point must exist.
% The text will not extend beyond the bottom of the page.
% At the end of this proc, the currentpoint will be one line below the last line, on the same page.
/fixed-line-breaks-1-font {
  4 dict begin
    { def } forall 
    currentpoint
    [/x0 /y0] defi
    /line-count 0 def
    lines str-lines {
      show % one line
      advance-the-line
    } forall
  end
} def

% new line: set the starting position (CR + LF)
/advance-the-line {
  % this proc uses data def'd by the caller
  /line-count line-count 1 add def
  x0
  y0 line-count leading mul sub
  moveto
} def

% lines-dict
% Render several lines of text with fixed line breaks, with possibly multiple fonts per line.
% The current point must exist.
% The text will not extend beyond the bottom of the page.
% At the end of this proc, the currentpoint will be one line below the last line, on the same page.
% SEE EXAMPLE DICT BELOW.
/fixed-line-breaks-N-fonts {
  4 dict begin
    { def } forall 
    currentpoint
    [/x0 /y0] defi
    /line-count 0 def
    lines {
      % line: an array of procs, one for each 'run'
      {
        % a run in a line
        exec
      } forall
      advance-the-line
    } forall
  end
} def

% str
% Intended for ALL CAPS text.
% (A better implementation would use 'small-caps' typeface here.)
/CAP {
  0.40 setcolor
  (capital) 100 use-font show
  0 setcolor
} bind def

% str
% Regular text.
/REG {
  (regular) 100 use-font show
} bind def

% str
% Italic text.
/ITAL {
  (italic) 100 use-font show
} bind def

% str
% Text of program code. Uses a fixed-width font.
/CODE {
  (fixed-width) 100 use-font show
} bind def

% str
% A code comment. Uses a fixed-width font.
/COM {
  0.33 setcolor
  (fixed-width-italic) 100 use-font show
  0 setcolor
} bind def

% x-pct y-pct
% moveto, but expressed using percentages of the /page-width and /page-height
/pmoveto {
  [/x-pct /y-pct] {
    page-width x-pct pct
    page-height y-pct pct
    moveto
  } def-tmp
} bind def

%%EndProlog

%%BeginSetup               
  /page-width  8.5 72 mul def
  /page-height 11 72 mul def % absolute values
  <</PageSize [page-width  page-height]>> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  /MyRegular /Helvetica latinize
  /MyCapital /Helvetica-Bold latinize
  /MyItalic /Helvetica-Oblique latinize
  /MyFixedWidth /Consolas latinize
  /MyFixedWidthItalic /Consolas-Italic latinize
  << 
    (regular) /MyRegular
    (capital) /MyCapital
    (italic) /MyItalic
    (fixed-width) /MyFixedWidth
    (fixed-width-italic) /MyFixedWidthItalic
  >>
  page-height 1.5 pct 
  init-my-fonts

%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
 /pgsave save def     
%%EndPageSetup

  (regular) 100 use-font
  5 95 pmoveto
  (Fixed line breaks, with multiple fonts:) show
  
  5 90 pmoveto
  << 
    /leading 1.75 em
    /lines [
      [ {(% x-pct y-pct)COM} ]
      [ {(% moveto, but expressed using percentages of)COM} ]
      [ {(% the /page-width and /page-height)COM}  ]
      [ {(/pmoveto {)CODE} ]
      [ {(  [/x-pct /y-pct] {)CODE} ]
      [ {(    page-width x-pct pct)CODE} ]
      [ {(    page-height y-pct pct)CODE} ]
      [ {(    moveto)CODE} {( % a new position)COM}]
      [ {(  } def-tmp)CODE} ]
      [ {(} bind def)CODE} ]
    ]
  >> fixed-line-breaks-N-fonts
  
  5 68 pmoveto
  << 
    /leading 1.75 em
    % a 'run' of text shares the same font. each run on a line has its own proc.
    /lines [
      [ {(OLIVIA. )CAP}  {(Ay me, detested, how am I beguiled!)REG} ]
      [ {(VIOLA. )CAP}  {(Who does beguile you? Who does do you wrong?)REG} ]
      [ {(OLIVIA. )CAP}  {(Hast thou forgot thyself? Is it so long?)REG} ]
      [ {(Call forth the holy father. )REG}  {(\(Exit an ATTENDANT.\))ITAL} ]
    ]
  >> fixed-line-breaks-N-fonts

  
  (regular) 100 use-font
  5 55 pmoveto
  (Fixed line breaks, with a single font:) show

  (fixed-width) 100 use-font
  5 50 pmoveto
  << 
    /leading 1.75 em
    /lines 
(% x-pct y-pct
% moveto, but expressed using percentages of
% the /page-width and /page-height
/pmoveto {
  [/x-pct /y-pct] {
    page-width x-pct pct
    page-height y-pct pct
    moveto
  } def-tmp
} bind def)
  >> fixed-line-breaks-1-font

  % when the font is fixed, the lines can be represented as one string.
  % the newlines in the string are are simply retained.
  (regular) 100 use-font
  5 28 pmoveto
  << 
    /leading 1.75 em
    /lines 
(OLIVIA. Ay me, detested, how am I beguiled!
VIOLA. Who does beguile you? Who does do you wrong?
OLIVIA. Hast thou forgot thyself? Is it so long?
Call forth the holy father. \(Exit an ATTENDANT.\))
  >> fixed-line-breaks-1-font

  

pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF 